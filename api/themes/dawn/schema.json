                    },
                    "settings_schema": [
                        { "key": "support_email", "label": "Support Email", "type": "text" },
                        { "key": "support_phone", "label": "Support Phone", "type": "text" },
                        { "key": "address", "label": "Address", "type": "textarea" }
                    ]
                }
            ]
        },
        "home": {
            "sections": [
                {
                    "type": "hero",
                    "settings": {
                        "title": "Welcome to Dawn",
