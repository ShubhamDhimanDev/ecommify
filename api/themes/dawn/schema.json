                            },
                            {
                                "title": "Support",
                                "links": [
                                    { "label": "Contact", "href": "/contact" },
                                    { "label": "FAQs", "href": "/faq" }
                                ]
                            }
                        ]
                    },
                    "settings_schema": [
                        { "key": "announcement_text", "label": "Announcement Text", "type": "text" },
                        { "key": "menu_items", "label": "Primary Menu Items", "type": "json", "hint": "Array of { label, href }" },
                        { "key": "mega_groups", "label": "Mega Menu Groups", "type": "json", "hint": "Array of { title, links[] }" }
                    ]
                }
            ]
        },
        "footer": {
            "sections": [
                {
                    "type": "footer-columns",
                    "settings": {
